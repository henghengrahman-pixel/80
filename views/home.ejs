<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover"/>

  <title><%= settings.siteName || "Live RTP Slot" %></title>

  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>

  <style>
    body{
      background:
        linear-gradient(rgba(0,0,0,.75), rgba(0,0,0,.85)),
        url("<%= settings.heroBackground || 'https://images.unsplash.com/photo-1511512578047-dfb367046420?q=80&w=1600&auto=format&fit=crop' %>") center/cover fixed no-repeat;
    }
  </style>
</head>
<body>

<div class="page-shell">

<!-- HEADER -->
<header class="brand-panel">
  <div class="brand-head">
    <% if (settings.logoUrl) { %>
      <img src="<%= settings.logoUrl %>" class="brand-logo" loading="eager"/>
    <% } else { %>
      <div class="brand-fallback"><%= settings.siteName %></div>
    <% } %>
  </div>
</header>

<!-- PROVIDERS -->
<section class="providers-shell">
  <div class="providers-scroll">
    <% providers.forEach(provider => { %>
      <div class="provider-item">
        <a href="/provider/<%= provider.slug %>" class="provider-link">
          <div class="provider-icon-wrap">
            <% if (provider.logoUrl) { %>
              <img src="<%= provider.logoUrl %>" class="provider-icon" loading="lazy" decoding="async"/>
            <% } %>
          </div>
          <div class="provider-name"><%= provider.name %></div>
        </a>
      </div>
    <% }) %>
  </div>
</section>

<!-- GAMES -->
<section class="content-panel">
  <div class="provider-games-grid" id="gamesGrid">
    <% games.forEach(game => { %>

      <% const score = Number(game.score || game.winrate || 0); %>
      <% const scoreClass = score >= 60 ? "high" : "medium"; %>

      <article class="provider-game-card">

        <% if (game.labelBadge) { %>
          <div class="game-badge"><%= game.labelBadge %></div>
        <% } %>

        <div class="provider-game-media">
          <a href="<%= settings.loginButtonLink %>" target="_blank">
            <img
              src="<%= game.imageUrl %>"
              alt="<%= game.title %>"
              loading="lazy"
              decoding="async"
            />
          </a>
        </div>

        <div class="provider-game-pattern">
          <div class="pattern-table">

            <% if (game.pattern && game.pattern.rows) { %>
              <% game.pattern.rows.forEach(row => { %>
                <div class="pattern-row">
                  <div class="pattern-label"><%= row.label %></div>
                  <div class="pattern-standard-right">
                    <span class="turbo-text <%= row.turbo === 'Turbo On' ? 'turbo-on' : 'turbo-off' %>">
                      <%= row.turbo %>
                    </span>
                    <span class="state-badge <%= row.result === '☑️' ? 'state-ok' : 'state-no' %>">
                      <%= row.result %>
                    </span>
                  </div>
                </div>
              <% }) %>
            <% } %>

          </div>

          <div class="time-row">
            Jam: <%= game.timeRange %>
          </div>

          <div class="score-box">
            <div class="score-fill <%= scoreClass %>" style="width:<%= score %>%">
              <span><%= score %>%</span>
            </div>
          </div>

        </div>
      </article>

    <% }) %>
  </div>
</section>

</div>

<script>
async function refreshGames(){
  try{
    const res = await fetch('/api/games');
    const data = await res.json();
    if(!data.success) return;

    const grid = document.getElementById('gamesGrid');

    grid.innerHTML = data.items.map(game=>{
      const score = Number(game.score || game.winrate || 0);
      const scoreClass = score >= 60 ? "high" : "medium";

      return `
      <article class="provider-game-card">
        ${game.labelBadge ? `<div class="game-badge">${game.labelBadge}</div>` : ""}

        <div class="provider-game-media">
          <a href="${game.gameLink || '#'}" target="_blank">
            <img src="${game.imageUrl}" loading="lazy" decoding="async"/>
          </a>
        </div>

        <div class="provider-game-pattern">
          <div class="pattern-table">
            ${(game.pattern?.rows || []).map(r=>`
              <div class="pattern-row">
                <div class="pattern-label">${r.label}</div>
                <div class="pattern-standard-right">
                  <span class="turbo-text ${r.turbo === 'Turbo On' ? 'turbo-on' : 'turbo-off'}">${r.turbo}</span>
                  <span class="state-badge ${r.result === '☑️' ? 'state-ok' : 'state-no'}">${r.result}</span>
                </div>
              </div>
            `).join("")}
          </div>

          <div class="time-row">Jam: ${game.timeRange}</div>

          <div class="score-box">
            <div class="score-fill ${scoreClass}" style="width:${score}%">
              <span>${score}%</span>
            </div>
          </div>
        </div>
      </article>`;
    }).join('');

  }catch(e){}
}

setInterval(refreshGames, 180000);
</script>

</body>
</html>
