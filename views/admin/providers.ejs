<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Providers</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *{margin:0;padding:0;box-sizing:border-box}:root{--bg:#090909;--panel:#131313;--line:rgba(255,255,255,.08);--line2:rgba(255,255,255,.14);--text:#fff;--soft:rgba(255,255,255,.68);--gold:#ffd36a;--red:#ff5a6b;--side:260px}body{min-height:100vh;font-family:Inter,sans-serif;background:linear-gradient(180deg,#070707,#101010);color:var(--text)}a{text-decoration:none;color:inherit}button,input,textarea,select{font:inherit}.layout{display:grid;grid-template-columns:var(--side) 1fr;min-height:100vh}.sidebar{padding:24px 16px;border-right:1px solid var(--line);background:#0f0f0f;position:sticky;top:0;height:100vh}.brand{padding:10px 12px 22px;border-bottom:1px solid var(--line);margin-bottom:18px}.brand strong{display:block;font-size:24px;font-weight:900;color:var(--gold)}.brand span{display:block;margin-top:6px;font-size:12px;color:var(--soft);font-weight:700;text-transform:uppercase;letter-spacing:.08em}.menu{display:flex;flex-direction:column;gap:8px}.menu a,.menu button{min-height:46px;border-radius:14px;padding:0 14px;display:flex;align-items:center;color:#fff;font-size:14px;font-weight:800;background:transparent;border:1px solid transparent;cursor:pointer}.menu a:hover,.menu button:hover{background:rgba(255,255,255,.04);border-color:var(--line)}.menu .active{color:#111;background:linear-gradient(180deg,#fff0b9,#ffcb2f)}.content{padding:24px}.top{display:flex;justify-content:space-between;gap:16px;align-items:flex-start;margin-bottom:20px}.top h1{font-size:34px;font-weight:900;line-height:1.08;margin-bottom:6px}.top p{color:var(--soft);font-size:14px;line-height:1.8;max-width:680px}.btn{min-height:44px;padding:10px 16px;border:none;border-radius:14px;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;gap:8px;font-size:14px;font-weight:800;transition:.2s ease}.btn-primary{color:#111;background:linear-gradient(180deg,#fff0b9,#ffcb2f)}.btn-dark{color:#fff;background:rgba(255,255,255,.06);border:1px solid var(--line2)}.btn-danger{color:#fff;background:linear-gradient(180deg,#ff7181,#ff4d5d)}.grid{display:grid;grid-template-columns:380px 1fr;gap:18px;align-items:start}.panel{border:1px solid var(--line);border-radius:22px;background:#131313;overflow:hidden;box-shadow:0 24px 60px rgba(0,0,0,.35)}.panel-head{padding:18px;border-bottom:1px solid var(--line)}.panel-head h2{font-size:22px;font-weight:900;margin-bottom:6px}.panel-head p{color:var(--soft);font-size:13px;line-height:1.7}.panel-body{padding:18px}.form-grid{display:grid;gap:14px}.form-group{display:grid;gap:8px}.form-label{font-size:13px;font-weight:800}.form-input{width:100%;height:50px;padding:0 14px;border-radius:14px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:#fff}.help{font-size:12px;line-height:1.6;color:var(--soft)}.check-wrap{min-height:50px;border-radius:14px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);display:flex;align-items:center;gap:10px;padding:0 14px}.check-wrap input{width:18px;height:18px;accent-color:#ffcb2f}.table-wrap{overflow:auto}table{width:100%;border-collapse:collapse;min-width:760px}th,td{padding:14px 16px;border-bottom:1px solid rgba(255,255,255,.06);vertical-align:middle;text-align:left;font-size:14px}th{font-size:12px;text-transform:uppercase;letter-spacing:.08em;color:rgba(255,255,255,.6);background:rgba(255,255,255,.02)}.provider-cell{display:flex;align-items:center;gap:12px;min-width:220px}.provider-logo,.provider-placeholder{width:52px;height:52px;border-radius:14px;background:rgba(255,255,255,.05);border:1px solid rgba(255,255,255,.08);flex:0 0 auto}.provider-logo{object-fit:contain;padding:8px}.provider-placeholder{display:flex;align-items:center;justify-content:center;font-size:12px;font-weight:900;color:var(--soft)}.provider-info strong{display:block;font-size:15px;font-weight:800;margin-bottom:4px}.provider-info span{display:block;font-size:12px;color:var(--soft);line-height:1.6;word-break:break-word}.badge{display:inline-flex;align-items:center;justify-content:center;min-height:30px;padding:6px 10px;border-radius:999px;font-size:12px;font-weight:900}.badge-active{background:rgba(37,192,109,.14);color:#7ff0b2;border:1px solid rgba(37,192,109,.22)}.badge-inactive{background:rgba(255,90,107,.12);color:#ffd4d9;border:1px solid rgba(255,90,107,.22)}.action-row{display:flex;gap:8px;flex-wrap:wrap}.btn-sm{min-height:36px;padding:8px 12px;border-radius:10px;font-size:12px;font-weight:900}.logout-form{display:block}@media(max-width:980px){.layout{grid-template-columns:1fr}.sidebar{position:relative;height:auto}.grid{grid-template-columns:1fr}.top{flex-direction:column}.menu{display:grid;grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:640px){.menu{grid-template-columns:1fr}.top h1{font-size:28px}}
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="brand"><strong>ADMIN</strong><span>Management Panel</span></div>
      <nav class="menu">
        <a href="/<%= adminPath %>/dashboard">Dashboard</a>
        <a href="/<%= adminPath %>/sliders">Slider</a>
        <a href="/<%= adminPath %>/providers" class="active">Provider</a>
        <a href="/<%= adminPath %>/games">Games</a>
        <a href="/<%= adminPath %>/settings">Settings</a>
        <form method="POST" action="/<%= adminPath %>/logout" class="logout-form"><button type="submit">Logout</button></form>
      </nav>
    </aside>
    <main class="content">
      <section class="top">
        <div><h1>Kelola Provider</h1><p>Halaman ini sudah sinkron dengan app.js. Route, form upload, dan menu admin sama semua.</p></div>
        <a href="/<%= adminPath %>/dashboard" class="btn btn-dark">Kembali Dashboard</a>
      </section>
      <section class="grid">
        <div class="panel">
          <div class="panel-head"><h2>Tambah Provider</h2><p>Tambah nama provider, logo, status aktif, dan urutan tampil.</p></div>
          <div class="panel-body">
            <form action="/<%= adminPath %>/providers/create" method="POST" enctype="multipart/form-data" class="form-grid">
              <div class="form-group"><label class="form-label">Nama Provider</label><input class="form-input" type="text" name="name" required /></div>
              <div class="form-group"><label class="form-label">Slug</label><input class="form-input" type="text" name="slug" placeholder="opsional" /></div>
              <div class="form-group"><label class="form-label">Upload Logo</label><input class="form-input" type="file" name="logoFile" accept="image/*" /></div>
              <div class="form-group"><label class="form-label">Atau URL Logo</label><input class="form-input" type="text" name="logoUrl" placeholder="https://domain.com/logo.png" /></div>
              <div class="form-group"><label class="form-label">Urutan Tampil</label><input class="form-input" type="number" name="sortOrder" value="0" /><div class="help">Angka kecil tampil lebih dulu.</div></div>
              <div class="check-wrap"><input id="isActive" type="checkbox" name="isActive" checked /><label for="isActive">Aktifkan provider</label></div>
              <button type="submit" class="btn btn-primary">Simpan Provider</button>
            </form>
          </div>
        </div>
        <div class="panel">
          <div class="panel-head"><h2>Daftar Provider</h2><p>Semua provider yang tersimpan di data JSON.</p></div>
          <div class="panel-body table-wrap">
            <table>
              <thead><tr><th>Provider</th><th>Status</th><th>Urutan</th><th>Aksi</th></tr></thead>
              <tbody>
                <% if (providers && providers.length) { %>
                  <% providers.forEach((provider) => { %>
                    <tr>
                      <td>
                        <div class="provider-cell">
                          <% if (provider.logoUrl) { %><img src="<%= provider.logoUrl %>" class="provider-logo" alt="<%= provider.name %>" /><% } else { %><div class="provider-placeholder"><%= (provider.name || 'P').slice(0,2).toUpperCase() %></div><% } %>
                          <div class="provider-info"><strong><%= provider.name %></strong><span><%= provider.slug %></span></div>
                        </div>
                      </td>
                      <td><span class="badge <%= provider.isActive !== false ? 'badge-active' : 'badge-inactive' %>"><%= provider.isActive !== false ? 'Aktif' : 'Nonaktif' %></span></td>
                      <td><%= provider.sortOrder || 0 %></td>
                      <td>
                        <div class="action-row">
                          <form method="POST" action="/<%= adminPath %>/providers/<%= provider.id %>/delete" onsubmit="return confirm('Hapus provider ini?')"><button type="submit" class="btn btn-danger btn-sm">Hapus</button></form>
                        </div>
                      </td>
                    </tr>
                  <% }) %>
                <% } else { %>
                  <tr><td colspan="4">Belum ada provider.</td></tr>
                <% } %>
              </tbody>
            </table>
          </div>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
