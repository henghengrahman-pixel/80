<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Sliders</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *{margin:0;padding:0;box-sizing:border-box}:root{--bg:#090909;--panel:#131313;--line:rgba(255,255,255,.08);--line2:rgba(255,255,255,.14);--text:#fff;--soft:rgba(255,255,255,.68);--gold:#ffd36a;--red:#ff5a6b;--green:#27c768;--side:260px}body{min-height:100vh;font-family:Inter,sans-serif;color:var(--text);background:linear-gradient(180deg,#070707,#101010)}a{text-decoration:none;color:inherit}button,input,textarea{font:inherit}.layout{display:grid;grid-template-columns:var(--side) 1fr;min-height:100vh}.sidebar{padding:24px 16px;border-right:1px solid var(--line);background:#0f0f0f;position:sticky;top:0;height:100vh}.brand{padding:10px 12px 22px;border-bottom:1px solid var(--line);margin-bottom:18px}.brand strong{display:block;font-size:24px;font-weight:900;color:var(--gold)}.brand span{display:block;margin-top:6px;font-size:12px;color:var(--soft);font-weight:700;text-transform:uppercase;letter-spacing:.08em}.menu{display:flex;flex-direction:column;gap:8px}.menu a,.menu button{min-height:46px;border-radius:14px;padding:0 14px;display:flex;align-items:center;color:#fff;font-size:14px;font-weight:800;background:transparent;border:1px solid transparent;cursor:pointer}.menu a:hover,.menu button:hover{background:rgba(255,255,255,.04);border-color:var(--line)}.menu .active{color:#111;background:linear-gradient(180deg,#fff0b9,#ffcb2f)}.content{padding:24px}.top{display:flex;align-items:flex-start;justify-content:space-between;gap:16px;margin-bottom:20px}.top h1{font-size:34px;line-height:1.08;font-weight:900;margin-bottom:6px}.top p{color:var(--soft);font-size:14px;line-height:1.8;max-width:720px}.btn{min-height:44px;padding:10px 16px;border:none;border-radius:14px;cursor:pointer;display:inline-flex;align-items:center;justify-content:center;gap:8px;font-size:14px;font-weight:800}.btn-primary{color:#111;background:linear-gradient(180deg,#fff0b9,#ffcb2f)}.btn-dark{color:#fff;background:rgba(255,255,255,.06);border:1px solid var(--line2)}.btn-danger{color:#fff;background:linear-gradient(180deg,#ff7181,#ff4d5d)}.grid{display:grid;grid-template-columns:390px 1fr;gap:18px;align-items:start}.panel{border:1px solid var(--line);border-radius:22px;background:#131313;overflow:hidden;box-shadow:0 24px 60px rgba(0,0,0,.35)}.panel-head{padding:18px;border-bottom:1px solid var(--line)}.panel-head h2{font-size:22px;font-weight:900;margin-bottom:6px}.panel-head p{color:var(--soft);font-size:13px;line-height:1.7}.panel-body{padding:18px}.form-grid{display:grid;gap:14px}.form-group{display:grid;gap:8px}.form-label{font-size:13px;font-weight:800}.form-input,.form-textarea{width:100%;border-radius:14px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:#fff}.form-input{height:50px;padding:0 14px}.form-textarea{min-height:100px;padding:14px;resize:vertical}.inline-2{display:grid;grid-template-columns:1fr 1fr;gap:12px}.check-wrap{min-height:50px;border-radius:14px;border:1px solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);display:flex;align-items:center;gap:10px;padding:0 14px}.check-wrap input{width:18px;height:18px;accent-color:#ffcb2f}.slider-list{display:grid;gap:14px}.slider-card{border:1px solid rgba(255,255,255,.08);border-radius:18px;overflow:hidden;background:rgba(255,255,255,.03)}.slider-image-wrap{position:relative;aspect-ratio:16/7;background:#111;overflow:hidden}.slider-image{width:100%;height:100%;object-fit:cover;display:block}.slider-overlay{position:absolute;inset:auto 0 0 0;padding:16px;background:linear-gradient(180deg,transparent,rgba(0,0,0,.78))}.slider-meta{padding:14px 16px 16px;display:grid;gap:12px}.badge{display:inline-flex;align-items:center;justify-content:center;min-height:30px;padding:6px 10px;border-radius:999px;font-size:12px;font-weight:900}.badge-active{background:rgba(37,192,109,.14);color:#7ff0b2;border:1px solid rgba(37,192,109,.22)}.badge-inactive{background:rgba(255,90,107,.12);color:#ffd4d9;border:1px solid rgba(255,90,107,.22)}.action-row{display:flex;gap:8px;flex-wrap:wrap}.logout-form{display:block}@media(max-width:980px){.layout{grid-template-columns:1fr}.sidebar{position:relative;height:auto}.grid{grid-template-columns:1fr}.top{flex-direction:column}.menu{display:grid;grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:640px){.menu{grid-template-columns:1fr}.inline-2{grid-template-columns:1fr}.top h1{font-size:28px}}
  </style>
</head>
<body>
  <div class="layout">
    <aside class="sidebar">
      <div class="brand"><strong>ADMIN</strong><span>Management Panel</span></div>
      <nav class="menu">
        <a href="/<%= adminPath %>/dashboard">Dashboard</a>
        <a href="/<%= adminPath %>/sliders" class="active">Slider</a>
        <a href="/<%= adminPath %>/providers">Provider</a>
        <a href="/<%= adminPath %>/games">Games</a>
        <a href="/<%= adminPath %>/settings">Settings</a>
        <form method="POST" action="/<%= adminPath %>/logout" class="logout-form"><button type="submit">Logout</button></form>
      </nav>
    </aside>
    <main class="content">
      <section class="top"><div><h1>Kelola Slider</h1><p>Form slider sudah sinkron dengan app.js. Route dan input file sekarang benar.</p></div><a href="/<%= adminPath %>/dashboard" class="btn btn-dark">Kembali Dashboard</a></section>
      <section class="grid">
        <div class="panel">
          <div class="panel-head"><h2>Tambah Slider</h2><p>Upload gambar slider atau isi URL gambar.</p></div>
          <div class="panel-body">
            <form action="/<%= adminPath %>/sliders/create" method="POST" enctype="multipart/form-data" class="form-grid">
              <div class="form-group"><label class="form-label">Judul Slider</label><input type="text" name="title" class="form-input"></div>
              <div class="form-group"><label class="form-label">Subtitle Slider</label><textarea name="subtitle" class="form-textarea"></textarea></div>
              <div class="form-group"><label class="form-label">Upload Gambar</label><input type="file" name="imageFile" class="form-input" accept="image/*"></div>
              <div class="form-group"><label class="form-label">Atau URL Gambar</label><input type="text" name="imageUrl" class="form-input" placeholder="https://domain.com/slider.jpg"></div>
              <div class="inline-2">
                <div class="form-group"><label class="form-label">Teks Tombol</label><input type="text" name="buttonText" class="form-input"></div>
                <div class="form-group"><label class="form-label">Link Tombol</label><input type="text" name="buttonLink" class="form-input"></div>
              </div>
              <div class="inline-2">
                <div class="form-group"><label class="form-label">Urutan Tampil</label><input type="number" name="sortOrder" class="form-input" value="0"></div>
                <div class="form-group"><label class="form-label">&nbsp;</label><div class="check-wrap"><input type="checkbox" id="isActive" name="isActive" checked><label for="isActive">Aktifkan slider</label></div></div>
              </div>
              <button type="submit" class="btn btn-primary">Simpan Slider</button>
            </form>
          </div>
        </div>
        <div class="panel">
          <div class="panel-head"><h2>Daftar Slider</h2><p>Slider aktif akan tampil di halaman utama sesuai urutan.</p></div>
          <div class="panel-body">
            <div class="slider-list">
              <% if (sliders && sliders.length) { %>
                <% sliders.forEach((slider) => { %>
                  <article class="slider-card">
                    <div class="slider-image-wrap">
                      <img src="<%= slider.imageUrl %>" alt="<%= slider.title || 'Slider' %>" class="slider-image">
                      <div class="slider-overlay"><h3><%= slider.title || '-' %></h3><p><%= slider.subtitle || '-' %></p></div>
                    </div>
                    <div class="slider-meta">
                      <div><span class="badge <%= slider.isActive !== false ? 'badge-active' : 'badge-inactive' %>"><%= slider.isActive !== false ? 'Aktif' : 'Nonaktif' %></span></div>
                      <div>Urutan: <%= slider.sortOrder || 0 %></div>
                      <div class="action-row"><form method="POST" action="/<%= adminPath %>/sliders/<%= slider.id %>/delete" onsubmit="return confirm('Hapus slider ini?')"><button type="submit" class="btn btn-danger">Hapus</button></form></div>
                    </div>
                  </article>
                <% }) %>
              <% } else { %>
                <p>Belum ada slider.</p>
              <% } %>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</body>
</html>
