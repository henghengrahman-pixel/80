<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin Games</title>
<meta name="robots" content="noindex,nofollow">
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">

<style>
*{margin:0;padding:0;box-sizing:border-box;}
body{
  font-family:Inter, sans-serif;
  background:#0b0b0b;
  color:#fff;
}

.admin-layout{
  display:grid;
  grid-template-columns:260px 1fr;
  min-height:100vh;
}

.sidebar{
  background:#111;
  border-right:1px solid rgba(255,255,255,.08);
  padding:20px;
}

.logo{
  font-size:22px;
  font-weight:900;
  color:#ffd36a;
  margin-bottom:30px;
}

.menu{
  display:flex;
  flex-direction:column;
  gap:10px;
}

.menu a{
  padding:12px 14px;
  border-radius:10px;
  text-decoration:none;
  color:#fff;
  background:#1a1a1a;
  font-size:14px;
  font-weight:700;
}

.menu a:hover,
.menu a.active{
  background:#ffd36a;
  color:#000;
}

.content{
  padding:30px;
}

h1{
  margin-bottom:20px;
  font-size:28px;
}

.grid{
  display:grid;
  grid-template-columns:350px 1fr;
  gap:20px;
}

.panel{
  background:#151515;
  border:1px solid rgba(255,255,255,.08);
  border-radius:15px;
  padding:20px;
}

.panel h2{
  margin-bottom:15px;
  font-size:20px;
}

.panel p.sub{
  font-size:13px;
  line-height:1.6;
  color:rgba(255,255,255,.65);
  margin-bottom:16px;
}

.form-group{
  margin-bottom:12px;
}

.form-group label{
  display:block;
  font-size:13px;
  margin-bottom:6px;
  font-weight:700;
}

.form-group input,
.form-group select{
  width:100%;
  height:44px;
  border-radius:10px;
  border:1px solid #333;
  background:#000;
  color:#fff;
  padding:0 12px;
}

.form-help{
  font-size:12px;
  line-height:1.6;
  color:rgba(255,255,255,.55);
  margin-top:6px;
}

button{
  background:#ffd36a;
  border:none;
  padding:11px 16px;
  border-radius:10px;
  font-weight:800;
  cursor:pointer;
}

button:hover{
  opacity:.95;
}

table{
  width:100%;
  border-collapse:collapse;
}

table th,
table td{
  padding:12px 10px;
  border-bottom:1px solid #333;
  font-size:13px;
  text-align:left;
  vertical-align:middle;
}

.thumb{
  width:64px;
  height:64px;
  object-fit:cover;
  border-radius:10px;
  border:1px solid rgba(255,255,255,.08);
  display:block;
}

.empty-thumb{
  width:64px;
  height:64px;
  border-radius:10px;
  border:1px solid rgba(255,255,255,.08);
  background:#000;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:11px;
  color:rgba(255,255,255,.45);
}

.delete-btn{
  background:#ff4d5d;
  color:#fff;
}

.note-box{
  margin-top:14px;
  padding:12px 14px;
  border-radius:12px;
  background:rgba(255,211,106,.08);
  border:1px solid rgba(255,211,106,.2);
  color:#ffe7a8;
  font-size:12px;
  line-height:1.7;
}

@media(max-width:900px){
  .admin-layout{
    grid-template-columns:1fr;
  }

  .grid{
    grid-template-columns:1fr;
  }

  .content{
    padding:18px;
  }

  .sidebar{
    padding:16px;
  }
}
</style>
</head>
<body>

<div class="admin-layout">

  <div class="sidebar">
    <div class="logo">ADMIN</div>
    <div class="menu">
      <a href="/itsiregar8008/dashboard">Dashboard</a>
      <a href="/itsiregar8008/sliders">Slider</a>
      <a href="/itsiregar8008/providers">Provider</a>
      <a href="/itsiregar8008/games" class="active">Games</a>
      <a href="/itsiregar8008/settings">Settings</a>
      <a href="/itsiregar8008/logout">Logout</a>
    </div>
  </div>

  <div class="content">
    <h1>Kelola Games</h1>

    <div class="grid">

      <div class="panel">
        <h2>Tambah Game</h2>
        <p class="sub">
          Tambah gambar game per provider. Nama game, link game, dan urutan tampil sudah tidak dipakai lagi.
        </p>

        <form action="/itsiregar8008/games" method="POST" enctype="multipart/form-data">
          <div class="form-group">
            <label>Provider</label>
            <select name="providerId" required>
              <% providers.forEach(p => { %>
                <option value="<%= p.id %>"><%= p.name %></option>
              <% }) %>
            </select>
          </div>

          <div class="form-group">
            <label>Upload Gambar Game</label>
            <input type="file" name="image" accept="image/*">
          </div>

          <div class="form-group">
            <label>Atau URL Gambar</label>
            <input type="text" name="imageUrl" placeholder="https://domain.com/game.jpg">
            <div class="form-help">Pilih salah satu: upload gambar atau isi URL gambar.</div>
          </div>

          <button type="submit">Simpan Game</button>
        </form>

        <div class="note-box">
          Semua game di home akan memakai link login utama dari Settings dan urutan tampil akan diacak otomatis.
        </div>
      </div>

      <div class="panel">
        <h2>Daftar Games</h2>

        <table>
          <thead>
            <tr>
              <th>Gambar</th>
              <th>Provider</th>
              <th>Hapus</th>
            </tr>
          </thead>
          <tbody>
            <% if (games.length === 0) { %>
              <tr>
                <td colspan="3">Belum ada data game.</td>
              </tr>
            <% } %>

            <% games.forEach(game => { %>
              <tr>
                <td>
                  <% if(game.imageUrl){ %>
                    <img src="<%= game.imageUrl %>" class="thumb" alt="Game <%= game.providerName %>">
                  <% } else { %>
                    <div class="empty-thumb">No Image</div>
                  <% } %>
                </td>
                <td><%= game.providerName %></td>
                <td>
                  <form action="/itsiregar8008/games/<%= game.id %>/delete" method="POST">
                    <button type="submit" class="delete-btn">Hapus</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>

      </div>

    </div>

  </div>

</div>

</body>
</html>
