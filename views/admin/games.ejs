<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Games</title>
  <meta name="robots" content="noindex,nofollow">
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&display=swap" rel="stylesheet">
  <style>
    *{margin:0;padding:0;box-sizing:border-box}body{font-family:Inter,sans-serif;background:#0b0b0b;color:#fff}.layout{display:grid;grid-template-columns:260px 1fr;min-height:100vh}.sidebar{background:#111;border-right:1px solid rgba(255,255,255,.08);padding:20px}.logo{font-size:22px;font-weight:900;color:#ffd36a;margin-bottom:30px}.menu{display:flex;flex-direction:column;gap:10px}.menu a,.menu button{padding:12px 14px;border-radius:10px;text-decoration:none;color:#fff;background:#1a1a1a;font-size:14px;font-weight:700;border:none;cursor:pointer;text-align:left}.menu a:hover,.menu a.active,.menu button:hover{background:#ffd36a;color:#000}.content{padding:30px}h1{margin-bottom:20px;font-size:28px}.grid{display:grid;grid-template-columns:360px 1fr;gap:20px}.panel{background:#151515;border:1px solid rgba(255,255,255,.08);border-radius:18px;padding:20px}.panel h2{margin-bottom:15px;font-size:20px}.panel p.sub{font-size:13px;line-height:1.6;color:rgba(255,255,255,.65);margin-bottom:16px}.form-group{margin-bottom:12px}.form-group label{display:block;font-size:13px;margin-bottom:6px;font-weight:700}.form-group input,.form-group select{width:100%;min-height:44px;border-radius:10px;border:1px solid #333;background:#000;color:#fff;padding:10px 12px}.inline-check{display:flex;align-items:center;gap:10px}.inline-check input{width:18px;height:18px}.form-help{font-size:12px;line-height:1.6;color:rgba(255,255,255,.55);margin-top:6px}button,.btn{background:#ffd36a;border:none;padding:11px 16px;border-radius:10px;font-weight:800;cursor:pointer;color:#000;display:inline-flex;align-items:center;justify-content:center}.btn-danger{background:#ff4d5d;color:#fff}.table-wrap{overflow:auto}table{width:100%;border-collapse:collapse;min-width:760px}th,td{padding:12px 10px;border-bottom:1px solid #333;font-size:13px;text-align:left;vertical-align:middle}.thumb,.empty-thumb{width:68px;height:68px;border-radius:10px;border:1px solid rgba(255,255,255,.08);display:block}.thumb{object-fit:cover}.empty-thumb{background:#000;display:flex;align-items:center;justify-content:center;font-size:11px;color:rgba(255,255,255,.45)}.tag{display:inline-flex;align-items:center;gap:6px;padding:5px 9px;border-radius:999px;background:rgba(255,211,106,.12);color:#ffe08e;font-size:11px;font-weight:800}.note-box{margin-top:14px;padding:12px 14px;border-radius:12px;background:rgba(255,211,106,.08);border:1px solid rgba(255,211,106,.2);color:#ffe7a8;font-size:12px;line-height:1.7}.logout-form{display:block}@media(max-width:900px){.layout{grid-template-columns:1fr}.grid{grid-template-columns:1fr}.content{padding:18px}.sidebar{padding:16px}.menu{display:grid;grid-template-columns:repeat(2,minmax(0,1fr))}}@media(max-width:640px){.menu{grid-template-columns:1fr}}
  </style>
</head>
<body>
<div class="layout">
  <div class="sidebar">
    <div class="logo">ADMIN</div>
    <div class="menu">
      <a href="/<%= adminPath %>/dashboard">Dashboard</a>
      <a href="/<%= adminPath %>/sliders">Slider</a>
      <a href="/<%= adminPath %>/providers">Provider</a>
      <a href="/<%= adminPath %>/games" class="active">Games</a>
      <a href="/<%= adminPath %>/settings">Settings</a>
      <form method="POST" action="/<%= adminPath %>/logout" class="logout-form"><button type="submit">Logout</button></form>
    </div>
  </div>
  <div class="content">
    <h1>Kelola Games</h1>
    <div class="grid">
      <div class="panel">
        <h2>Tambah Game</h2>
        <p class="sub">Game cukup pakai provider, URL gambar, dan status aktif. Link game ikut tombol login di home. Pola, jam, dan persen dibuat otomatis random.</p>
        <form action="/<%= adminPath %>/games/create" method="POST">
          <div class="form-group"><label>Provider</label><select name="providerId" required><option value="">Pilih provider</option><% providers.forEach(p => { %><option value="<%= p.id %>"><%= p.name %></option><% }) %></select></div>
          <div class="form-group"><label>URL Gambar</label><input type="url" name="imageUrl" placeholder="https://domain.com/game.jpg" required><div class="form-help">Upload file dihapus. Gunakan URL gambar saja.</div></div>
          <div class="form-group"><label class="inline-check"><input type="checkbox" name="isActive" checked> Aktifkan game</label></div>
          <button type="submit">Simpan Game</button>
        </form>
        <div class="note-box">Pragmatic Play pakai pola khusus. Provider lain pakai pola model PG/umum. Semua link game ikut login button dari settings.</div>
      </div>
      <div class="panel">
        <h2>Daftar Games</h2>
        <div class="table-wrap">
          <table>
            <thead><tr><th>Gambar</th><th>Game</th><th>Provider</th><th>Status</th><th>Aksi</th></tr></thead>
            <tbody>
              <% if (games && games.length) { %>
                <% games.forEach((game) => { %>
                  <tr>
                    <td><% if (game.imageUrl) { %><img src="<%= game.imageUrl %>" class="thumb" alt="<%= game.title %>"><% } else { %><div class="empty-thumb">NO IMG</div><% } %></td>
                    <td><strong><%= game.title %></strong><br><small><%= game.gameLink || settings.loginButtonLink || '#' %></small></td>
                    <td><%= game.providerName || '-' %></td>
                    <td><span class="tag"><%= game.isActive !== false ? 'Aktif' : 'Nonaktif' %></span></td>
                    <td><form action="/<%= adminPath %>/games/<%= game.id %>/delete" method="POST" onsubmit="return confirm('Hapus game ini?')"><button type="submit" class="btn btn-danger">Hapus</button></form></td>
                  </tr>
                <% }) %>
              <% } else { %>
                <tr><td colspan="5">Belum ada game.</td></tr>
              <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </div>
  </div>
</div>
</body>
</html>
