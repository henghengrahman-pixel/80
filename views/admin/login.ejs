<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta http-equiv="X-UA-Compatible" content="IE=edge" />
  <meta
    name="viewport"
    content="width=device-width, initial-scale=1, maximum-scale=1, viewport-fit=cover"
  />
  <title>Admin Login</title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap"
    rel="stylesheet"
  />

  <style>
    *{
      box-sizing:border-box;
      margin:0;
      padding:0;
    }

    :root{
      --bg:#050505;
      --panel:rgba(14,14,14,.92);
      --panel-2:rgba(24,24,24,.96);
      --line:rgba(255,255,255,.1);
      --line-2:rgba(255,255,255,.16);
      --text:#fff;
      --text-soft:rgba(255,255,255,.72);
      --gold:#ffd36a;
      --gold-2:#ffb703;
      --danger:#ff5a6b;
      --radius:22px;
      --shadow:0 30px 80px rgba(0,0,0,.45);
    }

    body{
      min-height:100vh;
      font-family:"Inter",sans-serif;
      color:var(--text);
      background:
        radial-gradient(circle at top left, rgba(255,211,106,.12), transparent 28%),
        radial-gradient(circle at bottom right, rgba(255,80,120,.08), transparent 24%),
        linear-gradient(rgba(0,0,0,.72), rgba(0,0,0,.84)),
        url("https://images.unsplash.com/photo-1511512578047-dfb367046420?q=80&w=1600&auto=format&fit=crop") center/cover fixed no-repeat;
      display:flex;
      align-items:center;
      justify-content:center;
      padding:20px;
      overflow:hidden;
    }

    .ambient{
      position:fixed;
      inset:0;
      pointer-events:none;
    }

    .ambient::before,
    .ambient::after{
      content:"";
      position:absolute;
      width:34vw;
      height:34vw;
      border-radius:999px;
      filter:blur(90px);
      opacity:.18;
    }

    .ambient::before{
      background:radial-gradient(circle, rgba(255,211,106,.75), transparent 65%);
      top:-10vw;
      left:-8vw;
    }

    .ambient::after{
      background:radial-gradient(circle, rgba(255,90,107,.55), transparent 65%);
      bottom:-10vw;
      right:-10vw;
    }

    .login-shell{
      width:min(100%, 1050px);
      display:grid;
      grid-template-columns: 1.08fr .92fr;
      border:1px solid var(--line-2);
      border-radius:28px;
      overflow:hidden;
      background:
        linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,.02)),
        linear-gradient(180deg, rgba(8,8,8,.95), rgba(14,14,14,.96));
      box-shadow:var(--shadow);
      backdrop-filter:blur(14px);
      position:relative;
      z-index:2;
    }

    .login-shell::before{
      content:"";
      position:absolute;
      inset:0;
      pointer-events:none;
      background:
        linear-gradient(120deg, rgba(255,255,255,.05), transparent 18%, transparent 84%, rgba(255,255,255,.04)),
        radial-gradient(circle at top right, rgba(255,211,106,.08), transparent 22%);
    }

    .login-hero{
      position:relative;
      padding:42px 36px;
      border-right:1px solid var(--line);
      overflow:hidden;
      display:flex;
      flex-direction:column;
      justify-content:space-between;
      min-height:640px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.02), rgba(255,255,255,.01)),
        linear-gradient(135deg, rgba(255,211,106,.08), rgba(255,255,255,0) 34%);
    }

    .hero-badge{
      display:inline-flex;
      align-items:center;
      gap:8px;
      width:max-content;
      min-height:38px;
      padding:8px 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.12);
      background:rgba(255,255,255,.05);
      color:var(--text-soft);
      font-size:12px;
      font-weight:800;
      text-transform:uppercase;
      letter-spacing:.08em;
    }

    .hero-badge::before{
      content:"";
      width:8px;
      height:8px;
      border-radius:999px;
      background:var(--gold);
      box-shadow:0 0 0 6px rgba(255,211,106,.14);
    }

    .hero-copy{
      max-width:520px;
      margin-top:28px;
    }

    .hero-copy h1{
      font-size:clamp(34px,4vw,56px);
      line-height:1.05;
      font-weight:900;
      letter-spacing:-.03em;
      margin-bottom:16px;
    }

    .hero-copy h1 span{
      background:linear-gradient(180deg,#fff,#ffd36a 70%,#ffb703);
      -webkit-background-clip:text;
      background-clip:text;
      color:transparent;
    }

    .hero-copy p{
      color:var(--text-soft);
      font-size:15px;
      line-height:1.8;
      max-width:460px;
    }

    .hero-cards{
      display:grid;
      grid-template-columns:repeat(2, minmax(0,1fr));
      gap:12px;
      margin-top:28px;
      max-width:520px;
    }

    .hero-card{
      border:1px solid rgba(255,255,255,.08);
      border-radius:18px;
      padding:16px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.02)),
        linear-gradient(180deg, rgba(20,20,20,.86), rgba(12,12,12,.92));
      box-shadow:0 18px 30px rgba(0,0,0,.2);
    }

    .hero-card strong{
      display:block;
      font-size:14px;
      margin-bottom:6px;
      font-weight:800;
    }

    .hero-card span{
      font-size:13px;
      line-height:1.65;
      color:var(--text-soft);
    }

    .hero-footer{
      margin-top:32px;
      display:flex;
      flex-wrap:wrap;
      gap:10px;
    }

    .hero-pill{
      min-height:38px;
      padding:8px 14px;
      border-radius:999px;
      border:1px solid rgba(255,255,255,.1);
      background:rgba(255,255,255,.04);
      display:inline-flex;
      align-items:center;
      justify-content:center;
      color:var(--text-soft);
      font-size:12px;
      font-weight:800;
    }

    .login-panel{
      position:relative;
      padding:34px;
      display:flex;
      align-items:center;
      justify-content:center;
      min-height:640px;
    }

    .login-card{
      width:100%;
      max-width:390px;
      border:1px solid rgba(255,255,255,.1);
      border-radius:24px;
      padding:28px;
      background:
        linear-gradient(180deg, rgba(255,255,255,.05), rgba(255,255,255,.02)),
        linear-gradient(180deg, rgba(18,18,18,.94), rgba(10,10,10,.96));
      box-shadow:0 24px 50px rgba(0,0,0,.28);
      backdrop-filter:blur(10px);
    }

    .logo-mark{
      width:64px;
      height:64px;
      border-radius:18px;
      display:flex;
      align-items:center;
      justify-content:center;
      margin-bottom:18px;
      background:linear-gradient(180deg,#fff0b9,#ffcb2f);
      color:#111;
      box-shadow:0 18px 28px rgba(255,203,47,.2);
    }

    .logo-mark svg{
      width:28px;
      height:28px;
    }

    .login-card h2{
      font-size:30px;
      line-height:1.1;
      font-weight:900;
      margin-bottom:10px;
      letter-spacing:-.03em;
    }

    .login-card p{
      color:var(--text-soft);
      line-height:1.75;
      font-size:14px;
      margin-bottom:22px;
    }

    .error-box{
      margin-bottom:16px;
      padding:12px 14px;
      border-radius:14px;
      border:1px solid rgba(255,90,107,.24);
      background:rgba(255,90,107,.1);
      color:#ffd4d9;
      font-size:13px;
      line-height:1.6;
      font-weight:700;
    }

    .form-group{
      margin-bottom:16px;
    }

    .form-label{
      display:block;
      font-size:13px;
      font-weight:800;
      color:#fff;
      margin-bottom:8px;
      letter-spacing:.01em;
    }

    .input-wrap{
      position:relative;
    }

    .form-input{
      width:100%;
      height:54px;
      border-radius:16px;
      border:1px solid rgba(255,255,255,.1);
      background:rgba(255,255,255,.04);
      color:#fff;
      padding:0 16px;
      outline:none;
      transition:border-color .2s ease, box-shadow .2s ease, background .2s ease;
    }

    .form-input::placeholder{
      color:rgba(255,255,255,.36);
    }

    .form-input:focus{
      border-color:rgba(255,211,106,.45);
      box-shadow:0 0 0 4px rgba(255,211,106,.08);
      background:rgba(255,255,255,.06);
    }

    .password-toggle{
      position:absolute;
      top:50%;
      right:12px;
      transform:translateY(-50%);
      height:34px;
      min-width:48px;
      border:none;
      border-radius:10px;
      background:rgba(255,255,255,.06);
      color:#fff;
      cursor:pointer;
      font-size:12px;
      font-weight:800;
      padding:0 10px;
    }

    .password-toggle:hover{
      background:rgba(255,255,255,.1);
    }

    .submit-btn{
      width:100%;
      height:56px;
      border:none;
      border-radius:16px;
      cursor:pointer;
      font-size:15px;
      font-weight:900;
      letter-spacing:.03em;
      color:#111;
      background:linear-gradient(180deg,#fff0b9,#ffcb2f);
      box-shadow:0 18px 30px rgba(255,203,47,.22);
      transition:transform .2s ease, filter .2s ease;
    }

    .submit-btn:hover{
      transform:translateY(-2px);
      filter:brightness(1.03);
    }

    .login-note{
      margin-top:16px;
      text-align:center;
      color:rgba(255,255,255,.5);
      font-size:12px;
      line-height:1.7;
    }

    .login-note strong{
      color:#fff;
    }

    .back-link{
      margin-top:18px;
      display:inline-flex;
      align-items:center;
      gap:8px;
      color:var(--text-soft);
      font-size:13px;
      font-weight:800;
    }

    .back-link:hover{
      color:#fff;
    }

    .back-link svg{
      width:16px;
      height:16px;
    }

    @media (max-width: 940px){
      .login-shell{
        grid-template-columns:1fr;
      }

      .login-hero{
        min-height:auto;
        border-right:none;
        border-bottom:1px solid var(--line);
        padding:28px 22px 24px;
      }

      .login-panel{
        min-height:auto;
        padding:22px;
      }

      .hero-copy{
        margin-top:20px;
      }

      .hero-copy p{
        max-width:none;
      }
    }

    @media (max-width: 560px){
      body{
        padding:12px;
      }

      .login-shell{
        border-radius:22px;
      }

      .login-hero{
        padding:20px 16px 18px;
      }

      .hero-copy h1{
        font-size:34px;
      }

      .hero-cards{
        grid-template-columns:1fr;
      }

      .login-panel{
        padding:16px;
      }

      .login-card{
        padding:22px 16px;
        border-radius:20px;
      }

      .login-card h2{
        font-size:26px;
      }

      .form-input{
        height:52px;
      }

      .submit-btn{
        height:54px;
      }
    }
  </style>
</head>
<body>
  <div class="ambient"></div>

  <main class="login-shell">
    <section class="login-hero">
      <div>
        <div class="hero-badge">Admin Access</div>

        <div class="hero-copy">
          <h1>Panel <span>Management</span> Modern</h1>
          <p>
            Kelola slider, provider, game, link tombol, running text, dan pengaturan
            tampilan dari satu panel admin yang rapi dan cepat diakses.
          </p>
        </div>

        <div class="hero-cards">
          <div class="hero-card">
            <strong>Kelola Konten</strong>
            <span>Atur data game, gambar, provider, dan urutan tampil dengan lebih mudah.</span>
          </div>
          <div class="hero-card">
            <strong>Atur Tampilan</strong>
            <span>Ubah logo, background, link tombol, running text, dan informasi halaman.</span>
          </div>
        </div>
      </div>

      <div class="hero-footer">
        <span class="hero-pill">Responsive</span>
        <span class="hero-pill">Fast Access</span>
        <span class="hero-pill">Simple Control</span>
      </div>
    </section>

    <section class="login-panel">
      <div class="login-card">
        <div class="logo-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 3 4 7v5c0 5 3.4 8.8 8 10 4.6-1.2 8-5 8-10V7l-8-4Z" stroke="currentColor" stroke-width="2" stroke-linejoin="round"/>
            <path d="m9.5 12 1.7 1.7 3.8-4.2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>

        <h2>Masuk Admin</h2>
        <p>Masukkan username dan password untuk masuk ke panel admin.</p>

        <% if (error) { %>
          <div class="error-box"><%= error %></div>
        <% } %>

       <form action="/itsiregar8008/login" method="POST" novalidate>
          <div class="form-group">
            <label class="form-label" for="username">Username</label>
            <div class="input-wrap">
              <input
                type="text"
                id="username"
                name="username"
                class="form-input"
                placeholder="Masukkan username"
                autocomplete="username"
                required
              />
            </div>
          </div>

          <div class="form-group">
            <label class="form-label" for="password">Password</label>
            <div class="input-wrap">
              <input
                type="password"
                id="password"
                name="password"
                class="form-input"
                placeholder="Masukkan password"
                autocomplete="current-password"
                required
              />
              <button type="button" class="password-toggle" id="togglePassword">Lihat</button>
            </div>
          </div>

          <button type="submit" class="submit-btn">Masuk Sekarang</button>
        </form>

        <div class="login-note">
          Username dan password admin mengikuti environment Railway:
          <strong>ADMIN_USERNAME</strong> dan <strong>ADMIN_PASSWORD</strong>
        </div>

        <a href="/" class="back-link">
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M15 18 9 12l6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <span>Kembali ke halaman utama</span>
        </a>
      </div>
    </section>
  </main>

  <script>
    const togglePassword = document.getElementById("togglePassword");
    const passwordInput = document.getElementById("password");

    if (togglePassword && passwordInput) {
      togglePassword.addEventListener("click", () => {
        const isPassword = passwordInput.type === "password";
        passwordInput.type = isPassword ? "text" : "password";
        togglePassword.textContent = isPassword ? "Tutup" : "Lihat";
      });
    }
  </script>
</body>
</html>
