<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || 'Login Admin' %></title>
  <meta name="robots" content="noindex,nofollow" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *{box-sizing:border-box;margin:0;padding:0}body{font-family:Inter,sans-serif;min-height:100vh;display:grid;place-items:center;background:linear-gradient(180deg,#070707,#101010);color:#fff;padding:24px}.card{width:100%;max-width:420px;background:#141414;border:1px solid rgba(255,255,255,.08);border-radius:24px;padding:24px;box-shadow:0 24px 60px rgba(0,0,0,.35)}h1{font-size:30px;font-weight:900;margin-bottom:8px}.muted{color:rgba(255,255,255,.65);line-height:1.7;font-size:14px;margin-bottom:18px}.error{background:rgba(255,90,107,.12);border:1px solid rgba(255,90,107,.24);color:#ffd8de;padding:12px 14px;border-radius:14px;margin-bottom:16px;font-size:13px}.group{display:grid;gap:8px;margin-bottom:14px}label{font-size:13px;font-weight:800}input{width:100%;height:50px;border-radius:14px;border:1px solid rgba(255,255,255,.1);background:#0e0e0e;color:#fff;padding:0 14px}button{width:100%;height:50px;border:none;border-radius:14px;font-weight:900;background:linear-gradient(180deg,#fff0b9,#ffcb2f);color:#111;cursor:pointer}.note{margin-top:16px;font-size:12px;line-height:1.7;color:rgba(255,255,255,.55)}
  </style>
</head>
<body>
  <div class="card">
    <h1>Login Admin</h1>
    <p class="muted">Masuk pakai username dan password dari environment variable Railway.</p>
    <% if (error) { %><div class="error"><%= error %></div><% } %>
    <form method="POST" action="/<%= adminPath %>/login">
      <div class="group">
        <label for="username">Username</label>
        <input id="username" name="username" type="text" required />
      </div>
      <div class="group">
        <label for="password">Password</label>
        <input id="password" name="password" type="password" required />
      </div>
      <button type="submit">Masuk</button>
    </form>
    <div class="note">Gunakan <b>ADMIN_USERNAME</b> / <b>ADMIN_PASSWORD</b> atau <b>ADMIN_ID</b> / <b>ADMIN_PASSWORD</b>.</div>
  </div>
</body>
</html>
